---
const { title, description, canonical, schema } = Astro.props
const pathname = Astro.url.pathname

import '../styles/globals.css'
import Navbar from '../components/Navbar.jsx'
import Footer from '../components/Footer.jsx'
import WhatsAppButton from '../components/WhatsAppButton.jsx'
import CookieBanner from '../components/CookieBanner.jsx'
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#08142A" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  {schema && <script type="application/ld+json" set:html={schema} />}

  <!-- ACTIVATE: replace G-XXXXXXXXXX with real GA4 ID to enable analytics -->
  <script is:inline>
    var GA4_ID = 'G-XXXXXXXXXX';

    function loadGA4() {
      if (document.getElementById('ga4-script')) return;
      var s = document.createElement('script');
      s.id = 'ga4-script';
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA4_ID;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', GA4_ID);
    }

    if (localStorage.getItem('cookie-consent') === 'accepted') {
      loadGA4();
    }
    window.addEventListener('cookie-consent-accepted', loadGA4);

    // AI referral tracking
    (function() {
      if (localStorage.getItem('cookie-consent') !== 'accepted') return;
      var referrer = document.referrer;
      if (!referrer) return;
      var aiDomains = [
        'perplexity.ai',
        'chatgpt.com',
        'claude.ai',
        'gemini.google.com',
        'copilot.microsoft.com',
        'you.com',
      ];
      var matched = null;
      try {
        var host = new URL(referrer).hostname;
        for (var i = 0; i < aiDomains.length; i++) {
          if (host === aiDomains[i] || host.endsWith('.' + aiDomains[i])) {
            matched = aiDomains[i];
            break;
          }
        }
      } catch(e) {}
      if (matched) {
        window.gtag?.('event', 'ai_referral', { referrer_domain: matched });
      }
    })();
  </script>
</head>
<body>
  <Navbar pathname={pathname} client:load />
  <main><slot /></main>
  <Footer client:load />
  <WhatsAppButton client:load />
  <CookieBanner client:load />

  <script is:inline>
    // IntersectionObserver for CSS scroll animations
    (function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { rootMargin: '-80px 0px', threshold: 0.05 });

      function observe() {
        document.querySelectorAll('.animate-on-scroll').forEach(function(el) {
          observer.observe(el);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', observe);
      } else {
        observe();
      }
    })();
  </script>
</body>
</html>
