---
const { faqs } = Astro.props

if (!faqs || faqs.length === 0) {
  return
}

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ question, answer }) => ({
    "@type": "Question",
    "name": question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": answer,
    },
  })),
}
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
