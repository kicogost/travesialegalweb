const data = {
  category: 'Extranjería y Residencia',
  categorySlug: 'extranjeria-y-residencia',
  title: 'Tarjeta Azul UE',
  titleLine1: 'Profesionales',
  titleLine2: 'Tarjeta Azul UE',
  description: 'La Tarjeta Azul UE es el permiso de trabajo para profesionales altamente cualificados de países no comunitarios. Ofrece una vía rápida y privilegiada para trabajar en Europa.',
  featuresTitle: 'Qué gestionamos',
  features: [
    { icon: 'Award', label: 'Solicitud de la Tarjeta Azul UE' },
    { icon: 'FileText', label: 'Verificación de titulación superior' },
    { icon: 'Briefcase', label: 'Contrato con salario mínimo exigido' },
