---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import ServiceSubpage from '../../../components/ServiceSubpage.jsx'

const data = {
  category: 'Extranjería y Residencia',
  categorySlug: 'extranjeria-y-residencia',
  title: 'Nómadas Digitales',
  titleLine1: 'Nómadas Digitales y',
  titleLine2: 'Teletrabajo',
  description: 'España ofrece el visado y la residencia para nómadas digitales: trabaja en remoto desde España para empresas o clientes extranjeros con plena legalidad. Te gestionamos el trámite completo.',
  featuresTitle: 'Qué gestionamos',
  features: [
    { icon: 'Wifi', label: 'Visado de nómada digital (desde consulado)' },
    { icon: 'Briefcase', label: 'Autorización de residencia para teletrabajo' },
    { icon: 'Globe', label: 'Verificación del empleador extranjero' },
    { icon: 'Calculator', label: 'Planificación fiscal (opción Ley Beckham)' },
    { icon: 'FileText', label: 'Documentación completa del expediente' },
    { icon: 'RefreshCw', label: 'Renovaciones anuales' },
  ],
  faqTitle: 'Preguntas frecuentes sobre el visado de nómada digital',
  faqItems: [
    {
      q: '¿Qué es el visado de nómada digital en España?',
      a: 'El visado de nómada digital, introducido por la Ley de Startups (Ley 28/2022), permite a trabajadores por cuenta ajena o por cuenta propia de empresas extranjeras vivir y trabajar en España en modalidad de teletrabajo. Está diseñado para personas que realizan toda o la mayor parte de su actividad laboral de forma remota para empleadores o clientes establecidos fuera de España.'
    },
    {
      q: '¿Cuáles son los requisitos para el visado de nómada digital?',
      a: 'Los principales requisitos son: acreditar que trabajas para una empresa o clientes extranjeros (la empresa española no puede representar más del 20% de los ingresos), disponer de ingresos mensuales de al menos el 200% del SMI (salario mínimo interprofesional, aproximadamente 2.400 €/mes en 2026), contar con seguro médico privado, y acreditar antecedentes penales limpios.'
    },
    {
      q: '¿Puedo acogerme a la Ley Beckham (régimen de impatriados) siendo nómada digital?',
      a: 'Sí. Los titulares del visado o autorización de nómada digital pueden acogerse al régimen fiscal especial de impatriados (Ley Beckham), que grava las rentas de fuente española al tipo fijo del 24% durante los primeros 6 años de residencia fiscal en España. Esto puede suponer un ahorro fiscal muy significativo frente al IRPF ordinario.'
    },
    {
      q: '¿Cuánto tiempo dura el visado de nómada digital y se puede renovar?',
      a: 'El visado inicial tiene una duración de 1 año. Tras residir en España, se puede solicitar la autorización de residencia para nómada digital, que tiene una duración de 3 años, renovable por períodos de 2 años adicionales. Durante la vigencia, el titular puede viajar libremente por la zona Schengen.'
    },
    {
      q: '¿Puedo incluir a mi familia en el visado de nómada digital?',
      a: 'Sí. Los familiares (cónyuge, pareja de hecho registrada e hijos menores) pueden solicitar conjuntamente la autorización de residencia por reagrupación familiar. Los cónyuges y parejas también pueden obtener autorización para trabajar en España, lo que hace de este visado una opción atractiva para familias.'
    },
  ],
  ctaTitle: '¿Trabajas en remoto y quieres vivir en España?',
  ctaDesc: 'Te ayudamos a obtener el visado de nómada digital y optimizar tu situación fiscal desde el primer día.',
}

const schema = JSON.stringify([
  { "@context": "https://schema.org", "@type": "LegalService", "name": "Travesía Legal", "url": "https://travesialegal.com", "telephone": "+34694269008", "address": [{ "@type": "PostalAddress", "streetAddress": "C/ Sardenya, 311", "addressLocality": "Barcelona", "postalCode": "08025", "addressCountry": "ES" }, { "@type": "PostalAddress", "streetAddress": "C/ Vallirana, 7 local", "addressLocality": "Sabadell", "postalCode": "08207", "addressCountry": "ES" }] },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": data.faqItems.map(i => ({ "@type": "Question", "name": i.q, "acceptedAnswer": { "@type": "Answer", "text": i.a } })) }
])
---
<BaseLayout
  title="Visado Nómada Digital en España: Teletrabajo Internacional | Travesía Legal"
  description="Tramitamos el visado de nómada digital y la residencia para teletrabajadores internacionales en España. Ley Beckham y planificación fiscal. Consulta gratuita."
  schema={schema}
  canonical="https://travesialegal.com/servicios/extranjeria-y-residencia/nomadas-digitales"
>
  <ServiceSubpage client:load data={data} />
</BaseLayout>
