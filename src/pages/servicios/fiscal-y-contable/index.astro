---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import ServiceSubpage from '../../../components/ServiceSubpage.jsx'

const data = {
  category: 'Servicios',
  categorySlug: '',
  title: 'Fiscal y Contable',
  titleLine1: 'Fiscal',
  titleLine2: 'y Contable',
  description: 'Asesoría fiscal y contable para autónomos, empresas y particulares en España. IRPF, IVA, Impuesto de Sociedades, Ley Beckham, planificación fiscal y más.',
  featuresTitle: 'Servicios fiscales y contables',
  features: [
    { icon: 'FileText', label: 'Declaración de la renta (IRPF)' },
    { icon: 'Briefcase', label: 'Gestión fiscal para autónomos y sociedades' },
    { icon: 'TrendingUp', label: 'Planificación fiscal estratégica' },
    { icon: 'Globe', label: 'Régimen de impatriados (Ley Beckham)' },
    { icon: 'BarChart2', label: 'Impuesto sobre el Patrimonio' },
    { icon: 'Scale', label: 'Impuesto de Sociedades (IS)' },
    { icon: 'Shield', label: 'Simulación fiscal e inspecciones' },
  ],
  faqTitle: 'Preguntas frecuentes sobre fiscalidad',
  faqItems: [
    {
      q: '¿Quién está obligado a presentar la declaración de la renta en España?',
      a: 'En general, están obligados a presentar el IRPF quienes tengan ingresos superiores a 22.000 € anuales de un solo pagador, o más de 15.000 € si hay varios pagadores. También están obligados quienes hayan percibido rentas del capital, rendimientos de actividades económicas o imputaciones de renta. Si tienes dudas sobre tu obligación de declarar, te la resolvemos en una consulta gratuita.'
    },
    {
      q: '¿Qué es la Ley Beckham y quién puede acogerse a ella?',
      a: 'La Ley Beckham (régimen especial de impatriados) permite a trabajadores que se trasladan a España por motivos laborales tributar en el IRPF a un tipo fijo del 24% sobre rendimientos de hasta 600.000 €, en lugar de aplicar la escala general progresiva. Para acogerse hay que no haber residido en España durante los 5 años anteriores y obtener el trabajo antes de venir o en los primeros 6 meses.'
    },
    {
      q: '¿Qué impuestos tiene que pagar un autónomo en España?',
      a: 'Un autónomo en España está sujeto principalmente al IRPF (trimestral y anual), al IVA (declaración trimestral y resumen anual) y, si tiene trabajadores, a las retenciones de nómina. También pueden aplicarse otros impuestos según la actividad. Gestionamos todos los modelos y declaraciones para que no tengas que preocuparte de los plazos fiscales.'
    },
    {
      q: '¿Cuándo tengo que presentar el Impuesto de Sociedades?',
      a: 'El Impuesto de Sociedades se presenta dentro de los 25 días siguientes a los 6 meses posteriores al cierre del ejercicio económico. Para la mayoría de empresas que cierran el 31 de diciembre, el plazo es del 1 al 25 de julio. Además, hay pagos fraccionados trimestrales (modelos 202) que hay que tener en cuenta durante el año.'
    },
    {
      q: '¿Qué es una inspección fiscal y cómo me ayudáis si la recibo?',
      a: 'Una inspección fiscal es un procedimiento de la Agencia Tributaria para verificar que has cumplido correctamente con tus obligaciones tributarias. Puede ser una comprobación limitada, una verificación de datos o una inspección completa. En Travesía Legal te acompañamos en todo el proceso: revisamos tu situación, preparamos la documentación y te representamos ante Hacienda.'
    },
  ],
  ctaTitle: '¿Necesitas asesoría fiscal o contable?',
  ctaDesc: 'Gestionamos tus impuestos y obligaciones contables para que puedas centrarte en tu negocio. Primera consulta gratuita.',
}

const schema = JSON.stringify([
  {
    "@context": "https://schema.org", "@type": "LegalService",
    "name": "Travesía Legal", "url": "https://travesialegal.com",
    "telephone": "+34694269008",
    "address": [
      { "@type": "PostalAddress", "streetAddress": "C/ Sardenya, 311", "addressLocality": "Barcelona", "postalCode": "08025", "addressCountry": "ES" },
      { "@type": "PostalAddress", "streetAddress": "C/ Vallirana, 7 local", "addressLocality": "Sabadell", "postalCode": "08207", "addressCountry": "ES" }
    ]
  },
  {
    "@context": "https://schema.org", "@type": "FAQPage",
    "mainEntity": data.faqItems.map(i => ({
      "@type": "Question", "name": i.q,
      "acceptedAnswer": { "@type": "Answer", "text": i.a }
    }))
  }
])
---
<BaseLayout
  title="Gestoría Fiscal y Contable en Barcelona y Madrid | Travesía Legal"
  description="Asesoría fiscal y contable: IRPF, IVA, Impuesto de Sociedades, Ley Beckham, planificación fiscal para autónomos y empresas. Consulta gratuita."
  schema={schema}
  canonical="https://travesialegal.com/servicios/fiscal-y-contable/"
>
  <ServiceSubpage client:load data={data} />
</BaseLayout>
